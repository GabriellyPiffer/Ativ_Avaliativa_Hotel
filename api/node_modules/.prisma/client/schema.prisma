generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model quarto {
  numero    Int    @id
  tipo      String
  descricao String
  imagem    String

  reserva reserva[]
}

model reserva {
  id      Int       @id @default(autoincrement())
  hospede String
  entrada DateTime  @default(now())
  saida   DateTime?
  numero  Int

  quarto quarto @relation(fields: [numero], references: [numero])
}
